{
  "manifest_version": 3,
  "name": "InstaFox",
  "version": "1.0.0",
  "description": "Post Instagram stories and enhanced features on desktop without switching to mobile view",
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "*://*.instagram.com/*",
    "*://*.cdninstagram.com/*"
  ],
  "background": {
    "scripts": ["background/service-worker.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["content/content.js"],
      "css": ["content/styles.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/inject.js",
        "ui/*.html",
        "ui/*.css",
        "ui/*.js",
        "icons/*"
      ],
      "matches": ["*://*.instagram.com/*"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    },
    "default_title": "InstaFox",
    "default_popup": "ui/popup.html"
  }
}
